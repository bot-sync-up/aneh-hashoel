# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aneh_hashoel

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-64-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
ACTION_LINK_SECRET=your-action-link-secret

# Encryption
ENCRYPTION_KEY=32-byte-hex-encryption-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# SendGrid
SENDGRID_API_KEY=SG.your-key
SENDGRID_FROM_EMAIL=noreply@aneh-hashoel.co.il
SENDGRID_FROM_NAME=ענה את השואל
SENDGRID_INBOUND_PARSE_SECRET=your-webhook-secret

# GreenAPI (WhatsApp)
GREENAPI_INSTANCE_ID=your-instance-id
GREENAPI_TOKEN=your-token

# WordPress
WP_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
WP_API_KEY=base64-encoded-user:app-password
WP_WEBHOOK_SECRET=your-webhook-secret

# Google Sheets (CRM)
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}

# Cron schedules (cron format, Israel timezone)
CRON_DAILY_DIGEST=0 8 * * *
CRON_WEEKLY_REPORT=0 8 * * 5
CRON_RABBI_OF_WEEK=0 9 * * 0
CRON_TIMEOUT_CHECK=*/30 * * * *
CRON_WP_SYNC_RETRY=0 * * * *
CRON_SHEETS_SYNC=*/15 * * * *

# MailWizz (optional — feature-flagged by MAILWIZZ_API_URL)
# MAILWIZZ_API_URL=https://mail.example.com/api
# MAILWIZZ_API_KEY=your-mailwizz-api-key
# MAILWIZZ_LIST_ID=your-list-uid

# System
TIMEOUT_HOURS=4
MAX_FOLLOW_UPS=1
