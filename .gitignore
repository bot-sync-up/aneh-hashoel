# ─────────────────────────────────────────────────────
#  ענה את השואל — .gitignore
# ─────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Environment files ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
backend/.env
frontend/.env

# Keep the example file committed
!.env.example
!backend/.env.example
!frontend/.env.example

# ── Build outputs ─────────────────────────────────────
dist/
build/
frontend/dist/
backend/dist/
.next/
out/

# ── Logs ──────────────────────────────────────────────
logs/
*.log
combined.log
error.log

# ── OS & editor artifacts ─────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing & coverage ────────────────────────────────
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/

# ── Docker local volumes ──────────────────────────────
docker/volumes/
.docker/

# ── Uploads (user-generated content) ─────────────────
uploads/
!uploads/.gitkeep

# ── Firebase credentials ──────────────────────────────
firebase-service-account*.json
serviceAccountKey*.json
google-services.json

# ── SSL certificates ──────────────────────────────────
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# ── Misc ──────────────────────────────────────────────
*.tgz
*.tar.gz
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
