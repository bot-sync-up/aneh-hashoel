# ─────────────────────────────────────────────────────────────────────────────
#  .env.production — העתק לקובץ .env ומלא את הערכים האמיתיים
#  אל תעלה קובץ זה ל-GitHub!
# ─────────────────────────────────────────────────────────────────────────────

# ── כללי ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aneh_hashoel
DB_USER=aneh_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── JWT ────────────────────────────────────────────────────────────────────────
# צור עם הפקודה: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=7d

# ── כתובות הפרונטאנד ────────────────────────────────────────────────────────────
VITE_API_URL=https://aneh.syncup.co.il
VITE_WS_URL=wss://aneh.syncup.co.il

# ── שאר השירותים (מלא לפי הצורך) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://aneh.syncup.co.il/api/auth/google/callback

GREENAPI_INSTANCE_ID=
GREENAPI_INSTANCE_TOKEN=
GREENAPI_WEBHOOK_SECRET=

MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=noreply@syncup.co.il

WORDPRESS_WEBHOOK_SECRET=

UPLOAD_MAX_SIZE_MB=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
