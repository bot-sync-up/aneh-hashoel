# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Copy to .env and fill in real values.
#  NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aneh_hashoel
DB_USER=aneh_user
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=7d

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── GreenAPI (WhatsApp) ───────────────────────────────────────────────────────
# Register at: https://green-api.com
GREENAPI_INSTANCE_ID=
GREENAPI_INSTANCE_TOKEN=
GREENAPI_WEBHOOK_SECRET=

# ── Mailgun ───────────────────────────────────────────────────────────────────
# Sign up at: https://mailgun.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
MAILGUN_INBOUND_WEBHOOK_SECRET=

# ── Firebase Admin SDK (FCM Push Notifications) ───────────────────────────────
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── WordPress Webhook ────────────────────────────────────────────────────────
# Set this to a long random string and configure it in the WP plugin settings
WORDPRESS_WEBHOOK_SECRET=

# ── Frontend (Vite build-time variables) ─────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_GOOGLE_CLIENT_ID=

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
